<!DOCTYPE html>
<html lang="zh">
<head>
<meta charset="UTF-8">
<title>Reading OS Pro</title>

<script src="https://cdn.jsdelivr.net/npm/epubjs/dist/epub.min.js"></script>

<style>
:root{
  --bg:#ffffff;
  --text:#222;
  --card:#f5f5f5;
}
.dark{
  --bg:#0f0f0f;
  --text:#eee;
  --card:#1a1a1a;
}

body{
  margin:0;
  font-family:-apple-system;
  background:var(--bg);
  color:var(--text);
}

/* 顶部 */
.header{
  display:flex;
  justify-content:space-between;
  padding:10px 20px;
  border-bottom:1px solid #ddd;
}

.views button{
  margin-right:10px;
}

/* 卡片 */
.grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(180px,1fr));
  gap:15px;
  padding:20px;
}

.card{
  background:var(--card);
  border-radius:12px;
  overflow:hidden;
  cursor:pointer;
}

.card img{
  width:100%;
  height:240px;
  object-fit:cover;
}

.card-title{
  padding:10px;
}

/* 详情抽屉 */
.drawer{
  position:fixed;
  right:-500px;
  top:0;
  width:500px;
  height:100%;
  background:var(--bg);
  transition:.3s;
  overflow:auto;
  padding:20px;
  border-left:1px solid #ddd;
}
.drawer.open{
  right:0;
}

/* 仪表盘 */
.dashboard{
  padding:20px;
  display:none;
}

/* 日历 */
.calendar{
  padding:20px;
  display:none;
}

/* 阅读器 */
#viewer{
  height:400px;
  border:1px solid #ccc;
}

</style>
</head>

<body>

<div class="header">
  <div>
    <button onclick="setView('grid')">📚</button>
    <button onclick="setView('dashboard')">📊</button>
    <button onclick="setView('calendar')">📅</button>
  </div>
  <div>
    <input placeholder="搜索..." oninput="search(this.value)">
    <button onclick="toggleDark()">🌙</button>
    <button onclick="addBook()">➕</button>
  </div>
</div>

<div id="grid" class="grid"></div>
<div id="dashboard" class="dashboard"></div>
<div id="calendar" class="calendar"></div>

<div id="drawer" class="drawer"></div>

<script>

/* 数据 */
let books = JSON.parse(localStorage.getItem("books")||"[]")

function save(){
  localStorage.setItem("books",JSON.stringify(books))
}

/* 默认数据 */
if(books.length===0){
  books=[
    {title:"三体",author:"刘慈欣",progress:60,status:"阅读中",tags:["科幻"],cover:"https://picsum.photos/200/300"}
  ]
  save()
}

/* 渲染 */
function render(list=books){
  let html=""
  list.forEach((b,i)=>{
    html+=`
      <div class="card" onclick="openDrawer(${i})">
        <img src="${b.cover||'https://picsum.photos/200/300'}">
        <div class="card-title">${b.title}</div>
      </div>`
  })
  document.getElementById("grid").innerHTML=html
}
render()

/* 搜索 */
function search(q){
  render(books.filter(b=>b.title.includes(q)))
}

/* 视图切换 */
function setView(v){
  grid.style.display="none"
  dashboard.style.display="none"
  calendar.style.display="none"
  document.getElementById(v).style.display="block"

  if(v==="dashboard") renderDashboard()
  if(v==="calendar") renderCalendar()
}

/* 抽屉 */
function openDrawer(i){
  let b=books[i]
  drawer.classList.add("open")
  drawer.innerHTML=`
    <h2>${b.title}</h2>
    <p>${b.author||""}</p>

    <p>状态：${b.status||""}</p>
    <p>标签：${(b.tags||[]).join(",")}</p>

    <progress value="${b.progress||0}" max="100"></progress>

    <button onclick="startRead(${i})">开始</button>
    <button onclick="endRead(${i})">结束</button>

    <h3>📎 附件</h3>
    <input placeholder="链接" value="${b.link||""}" onchange="updateLink(${i},this.value)">

    <h3>📖 EPUB</h3>
    <input type="file" onchange="loadEpub(event)">
    <div id="viewer"></div>
  `
}

/* 阅读 */
let startTime
function startRead(i){
  startTime=Date.now()
}
function endRead(i){
  let t=(Date.now()-startTime)/1000
  books[i].time=(books[i].time||0)+t
  save()
  alert("本次阅读："+Math.floor(t)+"秒")
}

/* 更新 */
function updateLink(i,v){
  books[i].link=v
  save()
}

/* 添加书 */
function addBook(){
  let title=prompt("书名")
  books.push({title,progress:0})
  save()
  render()
}

/* EPUB */
function loadEpub(e){
  let file=e.target.files[0]
  let book=ePub(file)
  let rendition=book.renderTo("viewer",{width:"100%",height:"100%"})
  rendition.display()
}

/* 仪表盘 */
function renderDashboard(){
  let total=books.length
  let finished=books.filter(b=>b.status==="已完成").length

  dashboard.innerHTML=`
    <h2>📊 阅读统计</h2>
    <p>总书籍：${total}</p>
    <p>已完成：${finished}</p>
  `
}

/* 日历 */
function renderCalendar(){
  calendar.innerHTML="<h2>📅 阅读日历（开发中）</h2>"
}

/* 黑夜模式 */
function toggleDark(){
  document.body.classList.toggle("dark")
}

</script>
</body>
</html>
